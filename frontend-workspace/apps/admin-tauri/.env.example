# ─── S3 / MinIO 对象存储（图片压缩上传管道） ───
# 这些变量由 image.rs 通过 std::env::var() 读取
# 开发时需要 export 或在启动 tauri dev 前设置

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=memory-stream
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminpassword
S3_PUBLIC_URL_BASE=http://127.0.0.1:9000/memory-stream

# ─── Go Server API ───
API_BASE_URL=http://localhost:8080/api/v1