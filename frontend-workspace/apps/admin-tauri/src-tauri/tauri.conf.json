{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "admin-tauri",
  "version": "0.1.0",
  "identifier": "com.gulugulu.admin-tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memory Stream",
        "width": 1280,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; connect-src 'self' ws://localhost:* wss://* https://*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.memory-stream.com/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": ""
    },
    "deep-link": {
      "schemes": ["memory-stream"]
    }
  }
}
