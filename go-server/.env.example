# ── Memory Stream Go Server ───────────────────────────────────────────────────
# Copy this file to .env and fill in values for local development.
# In production, set these as system environment variables or use .env.production.

# ── Server ──────────────────────────────────────────────────────────────────────
GO_ENV=development
GIN_MODE=debug
PORT=8080

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DATABASE_URL=host=127.0.0.1 user=root password=rootpassword dbname=devdb port=5432 sslmode=disable TimeZone=Asia/Shanghai

# ── Security (JWT) ─────────────────────────────────────────────────────────────
# REQUIRED in production (GO_ENV=production). Server will refuse to start without this.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# If unset, defaults to localhost origins for Tauri development.
# CORS_ORIGINS=https://reader.example.com,https://app.example.com

# ── Genesis Accounts ───────────────────────────────────────────────────────────
# Passwords for first-run admin/guest creation. Only used if no admin exists yet.
# Defaults: GENESIS_ADMIN_PASSWORD=admin123, GUEST_PASSWORD=guest123
# GENESIS_ADMIN_PASSWORD=
# GUEST_PASSWORD=

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── S3 (Asset Storage) ─────────────────────────────────────────────────────────
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=memory-stream
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL_BASE=http://127.0.0.1:9000/memory-stream
