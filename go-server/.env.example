# ─── Server ───
PORT=8080
GO_ENV=development  # Set to "production" to enforce JWT_SECRET requirement
DEBUG=true          # Set to "true" to enable debug logging (or use GIN_MODE=debug)
GIN_MODE=debug      # Gin mode: debug (verbose logging) | release (production)
WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:1420,http://localhost:4173

# ─── Database ───
DATABASE_URL=host=localhost user=postgres password=root dbname=memory_stream port=5432 sslmode=disable TimeZone=Asia/Shanghai

# ─── Redis ───
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ─── Security ───
# REQUIRED in production (GO_ENV=production). Server will refuse to start without it.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string-in-production
